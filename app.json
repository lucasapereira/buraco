{
  "expo": {
    "name": "Queti's Buraco",
    "slug": "buraco",
    "version": "2.1.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "buraco",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.lucasapereira.buraco"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#0D1117"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.lucasapereira.buraco",
      "versionCode": 62,
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#0D1117",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-font",
      "expo-image",
      "expo-web-browser",
      "expo-audio",
      "expo-asset",
      "@react-native-google-signin/google-signin",
      "expo-localization",
      [
        "./plugins/withLocalizedAppName",
        {
          "names": {
            "pt": "Queti's Buraco",
            "en": "Queti's Canasta",
            "es": "Queti's Canasta",
            "ru": "Queti's Бурако",
            "it": "Queti's Burraco",
            "zh": "Queti's 布拉柯",
            "lt": "Queti's Burako",
            "lv": "Queti's Burako",
            "et": "Queti's Burako"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
